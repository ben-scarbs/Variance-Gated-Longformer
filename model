#----Sparse Attention Transformer Model----
#   Inspired by Longformer
#   Uses windowed sparse attention with marginal dilation and selected global tokens
#   Additionally, uses variance dependant gated residuals and SwiGLU FFN sublayer

import math
import torch
from torch import nn
import torch.nn.functional as F


def _resolve_batch_padding_mask(padding_mask, batch_size, seq_len, device):
    if padding_mask is None:
        return None

    padding_mask = padding_mask.to(device=device, dtype=torch.bool)
    if padding_mask.dim() == 1:
        padding_mask = padding_mask.unsqueeze(0)

    if padding_mask.dim() != 2:
        raise ValueError(
            f"Expected padding mask with shape [batch, seq_len], got {tuple(padding_mask.shape)}"
        )

    if padding_mask.size(0) == 1 and batch_size > 1:
        padding_mask = padding_mask.expand(batch_size, -1)
    elif padding_mask.size(0) != batch_size:
        raise ValueError(
            f"Expected padding mask for batch size {batch_size}, got {padding_mask.size(0)}"
        )

    if padding_mask.size(1) != seq_len:
        raise ValueError(
            f"Expected padding mask for sequence length {seq_len}, got {padding_mask.size(1)}"
        )

    return padding_mask


class sparseAttention(nn.Module):
    def __init__(
        self,
        d_model: int = 512,  # embedding dim
        w: int = 128,  # local sparse window size (excludes global tokens)
        h: int = 8,  # number of heads; ALWAYS d_model % h == 0
        global_tokens_idx: torch.Tensor = torch.zeros(1,1, dtype=torch.long),  # absolute global token indices
        dilation: int = 1,  # dilation step for sparse margins
        next_global_k: int = 0,  # number of global tokens to route to the next layer
        carryover_global_k: int = 0,  # number of current globals to preserve into the next layer
    ):
        super().__init__()
        self.d_model = d_model
        self.w = w
        self.pad = w // 4
        self.step = dilation
        self.h = h
        assert d_model % h == 0
        self.d_h = d_model // h
        self.next_global_k = next_global_k
        self.carryover_global_k = carryover_global_k

        # qkv and w_0 weights
        self.w_qkv = nn.Parameter(torch.randn(h, 3 * self.d_h, d_model))
        self.w_0 = nn.Parameter(torch.randn(d_model, d_model))
        self.register_buffer("default_global_tokens", global_tokens_idx.to(torch.long))

        # local sparse offsets:
        # centre window: [-pad, ..., pad-1]  -> 2*pad tokens
        # margins: pad tokens on each side with dilation step
        centre = torch.arange(-self.pad, self.pad, dtype=torch.long)
        left_margin = -self.pad - torch.arange(1, self.pad + 1, dtype=torch.long) * self.step
        right_margin = (self.pad - 1) + torch.arange(1, self.pad + 1, dtype=torch.long) * self.step
        rel_offsets = torch.cat((left_margin, centre, right_margin))
        self.register_buffer("rel_offsets", rel_offsets)

    def _resolve_global_tokens(self, global_tokens_idx, batch_size, device):
        global_tokens = self.default_global_tokens if global_tokens_idx is None else global_tokens_idx
        global_tokens = global_tokens.to(device=device, dtype=torch.long)

        if global_tokens.dim() == 1:
            global_tokens = global_tokens.unsqueeze(0)

        if global_tokens.size(0) == 1 and batch_size > 1:
            global_tokens = global_tokens.expand(batch_size, -1)
        elif global_tokens.size(0) != batch_size:
            raise ValueError(
                f"Expected global token indices for batch size {batch_size}, got {global_tokens.size(0)}"
            )

        return global_tokens

    def _pad_selected_tokens(self, indices, total_k):
        if indices.size(1) >= total_k:
            return indices[:, :total_k]

        pad = indices.new_full((indices.size(0), total_k - indices.size(1)), -1)
        return torch.cat((indices, pad), dim=1)

    def _pack_valid_tokens(self, indices):
        if indices.numel() == 0:
            return indices

        B, N = indices.shape
        device = indices.device
        is_invalid = indices.lt(0)
        positions = torch.arange(N, device=device).unsqueeze(0).expand(B, -1)
        order = torch.argsort(is_invalid.to(torch.long) * N + positions, dim=1)
        return indices.gather(1, order)

    def _select_next_global_tokens(self, probs_global, global_tokens_safe, valid_global, valid_tokens):
        if self.next_global_k <= 0:
            return None

        B, _, G, L = probs_global.shape
        device = probs_global.device
        neg_large = torch.finfo(probs_global.dtype).min

        received_scores = probs_global.mean(dim=1)  # [B, G, L]

        if G > 0:
            self_mask = torch.zeros(B, G, L, dtype=torch.bool, device=device)
            self_mask.scatter_(2, global_tokens_safe.unsqueeze(-1), valid_global.unsqueeze(-1))
            received_scores = received_scores.masked_fill(self_mask, 0.0)

        valid_query_count = valid_global.sum(dim=1, keepdim=True).clamp_min(1).to(received_scores.dtype)
        token_scores = received_scores.sum(dim=1) / valid_query_count  # [B, L]

        carry_k = min(self.carryover_global_k, self.next_global_k, G)
        carried_idx = global_tokens_safe.new_empty(B, 0)
        fallback_idx = global_tokens_safe.new_empty(B, 0)

        if G > 0:
            global_scores = token_scores.gather(1, global_tokens_safe).masked_fill(~valid_global, neg_large)
            global_order = torch.argsort(global_scores, dim=1, descending=True)
            sorted_global_idx = global_tokens_safe.gather(1, global_order)
            sorted_global_valid = valid_global.gather(1, global_order)
            sorted_global_idx = sorted_global_idx.masked_fill(~sorted_global_valid, -1)

            carried_idx = sorted_global_idx[:, :carry_k]
            fallback_idx = sorted_global_idx[:, carry_k:]

        current_global_mask = torch.zeros(B, L, dtype=torch.bool, device=device)
        if G > 0:
            current_global_mask.scatter_(1, global_tokens_safe, valid_global)

        candidate_scores = token_scores.masked_fill(
            current_global_mask | ~valid_tokens,
            neg_large,
        )

        discover_k = min(self.next_global_k, L)
        discovered_idx = torch.topk(candidate_scores, k=discover_k, dim=-1).indices

        candidate_count = (valid_tokens & ~current_global_mask).sum(dim=1)
        rank = torch.arange(discover_k, device=device).unsqueeze(0)
        discovered_valid = rank < candidate_count.unsqueeze(1)
        discovered_idx = discovered_idx.masked_fill(~discovered_valid, -1)

        next_global_idx = torch.cat((carried_idx, discovered_idx, fallback_idx), dim=1)
        next_global_idx = self._pack_valid_tokens(next_global_idx)
        return self._pad_selected_tokens(next_global_idx, self.next_global_k)

    def forward(self, x, global_tokens_idx=None, padding_mask=None, return_next_global: bool = False):
        # x: [B, L, d_model]
        B, L, _ = x.shape
        padding_mask = _resolve_batch_padding_mask(padding_mask, B, L, x.device)
        if padding_mask is None:
            valid_tokens = torch.ones(B, L, dtype=torch.bool, device=x.device)
        else:
            valid_tokens = ~padding_mask

        # global indices must be valid for current sequence length.
        global_tokens = self._resolve_global_tokens(global_tokens_idx, B, x.device)  # [B, G]

        valid_global = (global_tokens >= 0) & (global_tokens < L)  # [B, G] (bool)
        global_tokens_safe = global_tokens.masked_fill(~valid_global, 0)
        if global_tokens_safe.numel() > 0:
            valid_global = valid_global & valid_tokens.gather(1, global_tokens_safe)
            global_tokens_safe = global_tokens.masked_fill(~valid_global, 0)

        global_mask = torch.zeros(B, L, dtype=torch.bool, device=x.device)
        if global_tokens_safe.numel() > 0:
            global_mask.scatter_(1, global_tokens_safe, valid_global)
        local_mask = valid_tokens & ~global_mask

        # q, k, v: [B, h, L, d_h]
        q, k, v = torch.einsum("bld,hkd->bhlk", x, self.w_qkv).chunk(3, dim=-1)

        # build sparse indices for local queries: relative local+dilated + absolute global
        base = torch.arange(L, device=x.device).view(1, L, 1)  # [1, L, 1]
        rel_offsets = self.rel_offsets.to(x.device).view(1, 1, -1)  # [1, 1, w]
        rel_idx = (base + rel_offsets).expand(B, -1, -1).clamp_min(0)  # [B, L, w]
        max_rel_idx = (valid_tokens.sum(dim=1).clamp_min(1) - 1).view(B, 1, 1)
        rel_idx = torch.minimum(rel_idx, max_rel_idx)
        rel_valid = valid_tokens.gather(1, rel_idx.reshape(B, -1)).reshape(B, L, -1)

        if global_tokens_safe.numel() > 0:
            glo_idx = global_tokens_safe.unsqueeze(1).expand(B, L, -1)  # [B, L, G]
            glo_valid = valid_global.unsqueeze(1).expand(B, L, -1)  # [B, L, G]
            sparse_idx = torch.cat((rel_idx, glo_idx), dim=-1)  # [B, L, w+G]
            sparse_valid = torch.cat((rel_valid, glo_valid), dim=-1)
        else:
            sparse_idx = rel_idx
            sparse_valid = rel_valid

        A = torch.zeros(B, self.h, L, self.d_h, device=x.device, dtype=x.dtype)

        S = sparse_idx.size(-1)
        neg_large = torch.finfo(x.dtype).min    # Finds the min value for x.dtype for masking.
        local_query_mask = local_mask.unsqueeze(1).unsqueeze(-1).to(x.dtype)  # [B, 1, L, 1]

        # Flatten [B, L] into a single axis to gather sparse keys/values without loops.
        batch_offsets = (torch.arange(B, device=x.device).view(B, 1, 1) * L)
        flat_sparse_idx = (sparse_idx + batch_offsets).reshape(B * L, S)  # [B*L, S]
        flat_k = k.permute(0, 2, 1, 3).reshape(B * L, self.h, self.d_h)  # [B*L, h, d_h]
        flat_v = v.permute(0, 2, 1, 3).reshape(B * L, self.h, self.d_h)  # [B*L, h, d_h]

        def run_local_attention():
            # k_local / v_local: [B, h, L, S, d_h]
            k_local = flat_k[flat_sparse_idx].reshape(B, L, S, self.h, self.d_h).permute(0, 3, 1, 2, 4)
            v_local = flat_v[flat_sparse_idx].reshape(B, L, S, self.h, self.d_h).permute(0, 3, 1, 2, 4)

            scores_local = torch.einsum("bhld,bhlwd->bhlw", q, k_local) / (self.d_h ** 0.5)
            local_key_mask = sparse_valid.unsqueeze(1)  # [B, 1, L, S]
            scores_local = scores_local.masked_fill(~local_key_mask, neg_large)
            probs_local = torch.softmax(scores_local, dim=-1).masked_fill(~local_key_mask, 0.0)
            local_out = torch.einsum("bhlw,bhlwd->bhld", probs_local, v_local)
            return local_out * local_query_mask

        def run_global_attention():
            G = global_tokens_safe.size(1)
            idx_global = global_tokens_safe.unsqueeze(1).unsqueeze(-1).expand(B, self.h, G, self.d_h)  # [B, h, G, d_h]
            q_global = q.gather(dim=2, index=idx_global)  # [B, h, G, d_h]
            scores_global = torch.einsum("bhgd,bhld->bhgl", q_global, k) / (self.d_h ** 0.5)

            valid_query = valid_global.unsqueeze(1).unsqueeze(-1)  # [B, 1, G, 1]
            valid_key = valid_tokens.unsqueeze(1).unsqueeze(1)  # [B, 1, 1, L]
            scores_for_softmax = scores_global.masked_fill(~valid_key, neg_large)
            scores_for_softmax = scores_for_softmax.masked_fill(~valid_query, 0.0)
            probs_global = torch.softmax(scores_for_softmax, dim=-1)
            probs_global = probs_global * valid_query.to(scores_global.dtype) * valid_key.to(scores_global.dtype)
            global_values = torch.einsum("bhgl,bhld->bhgd", probs_global, v)
            next_global_idx = self._select_next_global_tokens(
                probs_global,
                global_tokens_safe,
                valid_global,
                valid_tokens,
            )

            global_out = torch.zeros_like(q)
            global_out.scatter_add_(dim=2, index=idx_global, src=global_values)
            return global_out, next_global_idx

        # CPU path: keep sequential execution.
        if not x.is_cuda:
            local_out = run_local_attention()
            global_out, next_global_idx = run_global_attention()
            A = torch.where(global_mask.unsqueeze(1).unsqueeze(-1), global_out, local_out)
            out = A.transpose(1, 2).reshape(B, L, self.h * self.d_h)
            out = out @ self.w_0
            if return_next_global:
                return out, next_global_idx
            return out

        # CUDA path: run local and global blocks on separate streams for async computation.
        current_stream = torch.cuda.current_stream(device=x.device)
        local_stream = torch.cuda.Stream(device=x.device)
        global_stream = torch.cuda.Stream(device=x.device)

        local_out = None
        global_out = None
        next_global_idx = None

        local_stream.wait_stream(current_stream)
        with torch.cuda.stream(local_stream):
            local_out = run_local_attention()

        global_stream.wait_stream(current_stream)
        with torch.cuda.stream(global_stream):
            global_out, next_global_idx = run_global_attention()

        current_stream.wait_stream(local_stream)
        current_stream.wait_stream(global_stream)

        A = torch.where(global_mask.unsqueeze(1).unsqueeze(-1), global_out, local_out)

        out = A.transpose(1, 2).reshape(B, L, self.h * self.d_h)
        out = out @ self.w_0
        if return_next_global:
            return out, next_global_idx
        return out



class VarGatedResidual(nn.Module):
    """
    Residual scaling using:
      - sequence-level variance
      - token cosine distance from sequence mean

    x: [batch, seq_len, embedding_dim]
    """
    def __init__(
        self,
        alpha=0.5,
        beta=0.3
    ):
        super().__init__()
        self.alpha = nn.Parameter(torch.tensor(alpha))
        self.beta = nn.Parameter(torch.tensor(beta))

    def forward(self, x, padding_mask=None):
        # x: [B, L, d_model]
        B, L, d_model = x.shape
        if padding_mask is None:
            # ---- sequence mean ----
            mu = x.mean(dim=1, keepdim=True)  # [B, 1, d_model]

            # ---- cosine distance per token ----
            x_norm = F.normalize(x, dim=-1)
            mu_norm = F.normalize(mu, dim=-1)

            cos_sim = (x_norm * mu_norm).sum(dim=-1)  # [B, L]
            d = 1.0 - cos_sim                         # [B, L]

            # normalise token distances (mean ~ 1)
            d_mean = d.mean(dim=1, keepdim=True)
            d_norm = d / (d_mean + 1e-6)          # [B, L]

            # ---- sequence variance across tokens ----
            var_seq = x.var(dim=1, unbiased=False)    # [B, d_model]
            var_seq = var_seq.mean(dim=-1)            # [B]

            # normalize sequence variance
            var_mean = var_seq.mean(dim=0, keepdim=True)
            s_norm = var_seq / (var_mean + 1e-6)  # [B]

            # expand to tokens
            s_norm = s_norm.unsqueeze(1).expand(B, L)  # [B, L]

            # ---- combined gate ----
            gate = 1.0 + self.alpha * d_norm + self.beta * s_norm  # [B, L]

            return x * gate.unsqueeze(-1)   # [B, L, d_model]

        valid_tokens = (~padding_mask).to(x.dtype)
        valid_count = valid_tokens.sum(dim=1, keepdim=True).clamp_min(1.0)

        # ---- sequence mean ----
        mu = (x * valid_tokens.unsqueeze(-1)).sum(dim=1, keepdim=True) / valid_count.unsqueeze(-1)

        # ---- cosine distance per token ----
        x_norm = F.normalize(x, dim=-1)
        mu_norm = F.normalize(mu, dim=-1)

        cos_sim = (x_norm * mu_norm).sum(dim=-1)  # [B, L]
        d = (1.0 - cos_sim) * valid_tokens       # [B, L]

        # normalise token distances (mean ~ 1)
        d_mean = d.sum(dim=1, keepdim=True) / valid_count
        d_norm = d / (d_mean + 1e-6)          # [B, L]

        # ---- sequence variance across tokens ----
        centred = x - mu
        var_seq = (centred.pow(2) * valid_tokens.unsqueeze(-1)).sum(dim=1) / valid_count
        var_seq = var_seq.mean(dim=-1)            # [B]

        # normalize sequence variance
        var_mean = var_seq.mean(dim=0, keepdim=True)
        s_norm = var_seq / (var_mean + 1e-6)  # [B]

        # expand to tokens
        s_norm = s_norm.unsqueeze(1).expand(B, L)  # [B, L]

        # ---- combined gate ----
        gate = 1.0 + self.alpha * d_norm + self.beta * s_norm  # [B, L]

        return x * gate.unsqueeze(-1) * valid_tokens.unsqueeze(-1)   # [B, L, d_model]


class SwiGLUFFN(nn.Module):
    def __init__(
        self,
        d_model,
        d_ff,
        dropout=0.0
    ):
        super().__init__()
        self.w = nn.Parameter(torch.randn(d_model, d_ff*2))
        self.w_out = nn.Linear(d_ff, d_model)
        self.dropout = nn.Dropout(dropout)

    def forward(self, x):
        #   x: [B, L, d_model]
        w1, w2 = (x @ self.w).chunk(2, dim=-1)  # 2*[B, L, d_ff]
        x = F.silu(w1) * w2 # [B, L, d_ff]
        x = self.dropout(x)
        return self.w_out(x)    # [B, L, d_model]


class sparseTransformerLayer(nn.Module):
    def __init__(
        self,
        # Attention params
        d_model: int,
        w: int,
        global_tokens: torch.Tensor,
        dilation: int,
        next_global_k: int = 0,
        carryover_global_k: int = 0,
        # MLP params
        dropout: float = 0.0,
        hidden_ratio: float = 7/3
    ):
        super().__init__()
        self.sparseAttention = sparseAttention(
            d_model = d_model,
            w = w,
            global_tokens_idx = global_tokens,
            dilation = dilation,
            next_global_k = next_global_k,
            carryover_global_k = carryover_global_k,
        )

        hidden_dim = int(hidden_ratio * d_model)
        self.FFN = SwiGLUFFN(d_model=d_model, d_ff=hidden_dim, dropout=dropout)

        self.residual1 = VarGatedResidual()
        self.residual2 = VarGatedResidual()

        self.norm1 = nn.RMSNorm(d_model)
        self.norm2 = nn.RMSNorm(d_model)

    def forward(self, x, global_tokens_idx=None, padding_mask=None, return_next_global: bool = False):
        padding_mask = _resolve_batch_padding_mask(padding_mask, x.size(0), x.size(1), x.device)
        #   Sublayer 1 (Attention)
        sub1 = self.norm1(x)
        attn_out = self.sparseAttention(
            sub1,
            global_tokens_idx=global_tokens_idx,
            padding_mask=padding_mask,
            return_next_global=return_next_global,
        )
        next_global_idx = None
        if return_next_global:
            attn_out, next_global_idx = attn_out
        sub1 = x + self.residual1(attn_out, padding_mask=padding_mask)
        #   Sublayer 2 (FFN)
        sub2 = self.norm2(sub1)
        sub2 = self.FFN(sub2)
        sub2 = sub1 + self.residual2(sub2, padding_mask=padding_mask)
        if return_next_global:
            return sub2, next_global_idx
        return sub2
